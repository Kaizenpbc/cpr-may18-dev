# =============================================================
# CPR Training System — Root Environment Variables Example
# Copy to .env and fill in real values. Never commit .env.
# =============================================================

# Node environment (development | staging | production)
NODE_ENV=development

# Server
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# Database (use DATABASE_URL for Neon/cloud, or individual fields for local Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cpr_may18
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
REFRESH_TOKEN_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_ACCESS_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_RESET_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE

# JWT expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email (Gmail SMTP — use an App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM=noreply@yourdomain.com
EMAIL_ENABLED=false

# Redis (disabled by default on TMD)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=YOUR_SESSION_SECRET_HERE

# Google Cloud Vision (optional)
GOOGLE_CLOUD_KEY_FILE=./gtacpr-ocr-266c4803c5bc.json
GOOGLE_CLOUD_PROJECT_ID=gtacpr-ocr

# CORS
CORS_ORIGIN=http://localhost:5173
