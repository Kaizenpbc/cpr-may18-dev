# =============================================================
# CPR Training System — Backend Environment Variables Example
# Copy to backend/.env and fill in real values.
# Never commit backend/.env (it is gitignored).
# =============================================================

# Node environment
NODE_ENV=development

# Server
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# Database — prefer DATABASE_URL for cloud/Neon connections
# DATABASE_URL takes precedence when set (used on TMD production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cpr_may18
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000

# JWT secrets (minimum 32 chars; 64-char hex recommended for production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
REFRESH_TOKEN_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_ACCESS_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE
JWT_RESET_SECRET=YOUR_64_CHAR_HEX_SECRET_HERE

# Token expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Default seeded account passwords (only used during db:init)
DEFAULT_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
DEFAULT_INSTRUCTOR_PASSWORD=YOUR_INSTRUCTOR_PASSWORD_HERE
DEFAULT_ORG_PASSWORD=YOUR_ORG_PASSWORD_HERE
DEFAULT_ACCOUNTANT_PASSWORD=YOUR_ACCOUNTANT_PASSWORD_HERE

# Redis (disabled on TMD — stub prevents crash)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# Email (Gmail SMTP — use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM=noreply@cpr-training.com
EMAIL_ENABLED=false

# Encryption
DB_ENCRYPTION_KEY=YOUR_32_CHAR_HEX_ENCRYPTION_KEY_HERE
SESSION_SECRET=YOUR_SESSION_SECRET_HERE

# App metadata
APP_NAME=CPR Training Management System
SUPPORT_EMAIL=support@cpr-training.com
MAX_FILE_SIZE=10485760

# Google Cloud Vision (optional OCR feature)
GOOGLE_CLOUD_KEY_FILE=./gtacpr-ocr-266c4803c5bc.json
GOOGLE_CLOUD_PROJECT_ID=gtacpr-ocr

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
